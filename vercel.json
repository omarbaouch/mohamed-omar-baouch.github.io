{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ask-*.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/assets/:file(.*-[a-zA-Z0-9_-]{8}\\.[a-z0-9]+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
